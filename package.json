{
  "name": "@bauer-group/ai-act-compliance",
  "version": "0.0.0",
  "description": "Compliance-Dokumentation für den EU AI Act (Verordnung (EU) 2024/1689)",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:clean": "rm -rf docs/.vitepress/dist docs/.vitepress/cache",
    "lint": "markdownlint-cli2 \"docs/**/*.md\"",
    "lint:fix": "markdownlint-cli2 --fix \"docs/**/*.md\"",
    "validate": "npm run lint && npm run docs:build",
    "ci": "npm ci && npm run lint && npm run docs:build"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.17.0",
    "vitepress": "^1.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bauer-group/SEC-AIActCompliance.git"
  },
  "author": "BAUER GROUP GmbH & Co. KG",
  "license": "SEE LICENSE IN LICENSE"
}
